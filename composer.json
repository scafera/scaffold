{
    "name": "scafera/scaffold",
    "description": "Composer plugin that scaffolds framework files into Scafera projects",
    "type": "composer-plugin",
    "license": "MIT",
    "require": {
        "php": ">=8.4",
        "composer-plugin-api": "^2.0"
    },
    "require-dev": {
        "composer/composer": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Scafera\\Scaffold\\": "src/"
        }
    },
    "extra": {
        "class": "Scafera\\Scaffold\\ScaffoldPlugin"
    }
}
